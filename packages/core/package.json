{
  "name": "@codeflow/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./branches": {
      "import": "./dist/branches/index.js"
    },
    "./git": {
      "import": "./dist/git/index.js"
    },
    "./graph/knowledge-graph": {
      "import": "./dist/graph/knowledge-graph.js"
    },
    "./metrics": {
      "import": "./dist/metrics/index.js"
    },
    "./pipeline": {
      "import": "./dist/pipeline/index.js"
    },
    "./schema": {
      "import": "./dist/schema/index.js"
    },
    "./search": {
      "import": "./dist/search/index.js"
    },
    "./storage": {
      "import": "./dist/storage/index.js"
    },
    "./storage/edge-store": {
      "import": "./dist/storage/edge-store.js"
    },
    "./storage/node-store": {
      "import": "./dist/storage/node-store.js"
    },

    "./taint": {
      "import": "./dist/taint/index.js"
    },
    "./tests": {
      "import": "./dist/tests/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "commander": "^13.1.0",
    "glob": "^11.0.0",
    "graphology": "^0.25.4",
    "graphology-indices": "^0.17.0",
    "graphology-utils": "^2.3.0",
    "ignore": "^7.0.5",
    "lru-cache": "^11.0.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.3",
    "simple-git": "^3.27.0",
    "tree-sitter": "^0.22.4",
    "tree-sitter-c": "^0.23.4",
    "tree-sitter-c-sharp": "^0.23.1",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.23.4",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-php": "^0.23.12",
    "tree-sitter-python": "^0.23.6",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.23.2",
    "tree-sitter-typescript": "^0.23.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.12.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
